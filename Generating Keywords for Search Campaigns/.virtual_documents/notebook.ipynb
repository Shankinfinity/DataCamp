





import pandas as pd


# Start coding here
# Use as many cells as you need


products = ['sofas', 'convertible sofas', 'love seats', 'recliners', 'sofa beds']
words = ['buy', 'discount', 'sale', 'cheap', 'prices', 'best', 'offers', 'online', 'shop', 'store', 'deals', 'affordable']


keywords_list = []

for product in products:
    for word in words:
        keywords_list.append([product, f"{word} {product}"])
        keywords_list.append([product, f"{product} {word}"])


keywords_df = pd.DataFrame(keywords_list, columns=['Ad Group', 'Keyword'])

keywords_df['Campaign'] = 'SEM_Sofas'
keywords_df['Criterion Type'] = 'Exact'


keywords_df.to_csv('keywords.csv', index=False)


print(keywords_df.head(10))
print(f"Total keywords generated: {len(keywords_df)}")
